{% extends 'base.html.twig' %}

{% block title %}Ajouter un livre{% endblock %}

{% block body %}
  <div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h2 class="h4 mb-0">Ajouter un livre</h2>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="mb-3">
                            {{ form_row(form.titre) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(form.auteur) }}
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.isbn) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.stock) }}
                            </div>
                        </div>
                        <div class="mb-3">
                            {{ form_row(form.resume) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(form.image) }}
                        </div>
                        
                        <button class="btn btn-success w-100">
                            Enregistrer le livre
                        </button>
                    {{ form_end(form) }}
                </div>
            </div>
            <div class="mt-3">
                <a href="{{ path('app_book_index') }}" class="text-secondary small">← Retour à la liste</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
