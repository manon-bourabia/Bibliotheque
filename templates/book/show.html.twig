{% extends 'base.html.twig' %}

{% block title %}Détails - {{ book.titre }}{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-4 mb-4 mb-md-0">
                    <div class="text-center">
                        <img src="{{ asset('images/' ~ book.image) }}" 
                             class="img-fluid rounded shadow" 
                             alt="{{ book.titre }}"
                             style="max-height: 500px; object-fit: cover;">
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="d-flex justify-content-between align-items-start">
                        <h1 class="display-5 fw-bold">{{ book.titre }}</h1>
                        <div>
                            {% if book.stock > 0 %}
                                <span class="badge bg-success fs-6">Disponible ({{ book.stock }})</span>
                            {% else %}
                                <span class="badge bg-danger fs-6">Indisponible</span>
                            {% endif %}
                        </div>
                    </div>

                    <p class="text-muted fs-4">par <strong>{{ book.auteur }}</strong></p>
                    
                    <hr>

                    <h5 class="fw-bold">Résumé</h5>
                    <p class="text-secondary" style="text-align: justify; line-height: 1.6;">
                        {{ book.resume|default('Aucun résumé disponible pour ce livre.') }}...
                    </p>

                    <div class="mt-5 d-flex gap-2">
                        <a href="{{ path('app_home') }}" class="btn btn-outline-secondary px-2">
                            <i class="bi bi-arrow-left"></i> Retour
                        </a>

                        {% if book.stock > 0 %}
                            <a href="{{ path('app_emprunt_new', {'id': book.id}) }}" class="btn btn-info btn px-2 shadow">
                                Emprunter ce livre
                            </a>
                        {% else %}
                            <button class="btn btn-secondary btn px-5" disabled>
                                Victime de son succès
                            </button>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}