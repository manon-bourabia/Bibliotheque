{% extends 'base.html.twig' %}

{% block title %}Statistiques{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-blue-200 text-white p-3">
            <h2 class="h4 mb-0">Statistiques par Auteur</h2>
        </div>

        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3">Auteur</th>
                        <th class="text-center py-3">Nombre de livres</th>
                    </tr>
                </thead>
                <tbody>
                    {% for stat in stats %}
                        <tr>
                            <td class="ps-4">
                                <strong class="text-dark">{{ stat.auteur }}</strong>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-blue-200 text-dark rounded-pill px-3">
                                    {{ stat.total }}
                                </span>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="2" class="text-center py-4 text-muted">
                                Aucune donnée disponible.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <a href="{{ path('app_book_index') }}" class="btn btn-link text-secondary text-decoration-none small">
            ← Retour au catalogue
        </a>
    </div>
</div>
{% endblock %}