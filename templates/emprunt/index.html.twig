{% extends 'base.html.twig' %}

{% block title %}Mes Emprunts
{% endblock %}

{% block body %}
	<div class="container mt-4">
		<div class="d-flex justify-content-between align-items-center mb-4">
			<h1>Liste des Emprunts ({{ emprunts|length }})</h1>
			<a href="{{ path('app_book_index') }}" class="btn btn-outline-secondary btn-sm">Retour aux livres</a>
		</div>

		<div class="card shadow-sm">
			<div class="card-body">
				<table class="table table-hover mb-0">
					<thead class="table-light">
						<tr>
							<th>Livre</th>
							<th>Emprunteur</th>
							<th>Date d'emprunt</th>
							<th>Statut</th>
							<th class="text-end">Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for emprunt in emprunts %}
							<tr>
								<td class="align-middle">
									<strong>{{ emprunt.book.titre }}</strong>
								</td>
								<td class="align-middle">
									{{ emprunt.user.firstName }}
									{{ emprunt.user.lastName }}
								</td>
								<td class="align-middle">
									{{ emprunt.dateEmprunt|date('d/m/Y') }}
								</td>
								<td class="align-middle">
									{% if emprunt.dateRetour %}
										<span class="badge {{ emprunt.statut == 'rendu' ? 'bg-success' : 'bg-warning text-dark' }}">
											{{ emprunt.statut|upper }}
										</span>

										{% if emprunt.dateRetour %}
											<small class="text-muted d-block">le
												{{ emprunt.dateRetour|date('d/m/Y') }}</small>
										{% endif %}
									</td>
								</td>
								<td class="text-end align-middle">
									<div class="btn-group">
										<a href="{{ path('app_emprunt_show', {'id': emprunt.id}) }}" class="btn btn-sm btn-info text-white">
											<i class="fas fa-eye"></i>
											Détail
										</a>

										{% if not emprunt.dateRetour %}
											<a href="{{ path('app_emprunt_rendre', {'id': emprunt.id}) }}" class="btn btn-sm btn-success" onclick="return confirm('Confirmer le retour de ce livre ?')">
												Rendre
											</a>
										{% endif %}
									</div>
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="5" class="text-center py-4 text-muted">
									<em>Aucun emprunt enregistré pour le moment.</em>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>
{% endblock %}
