{% extends 'base.html.twig' %}

{% block title %}Mon Historique{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Historique de {{ user.firstName }} {{ user.lastName }}</h1>
        <span class="badge bg-primary">{{ emprunts|length }} emprunt(s) au total</span>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Livre</th>
                        <th>Date d'emprunt</th>
                        <th>Date de retour</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    {% for emprunt in emprunts %}
                        <tr>
                            <td>
                                <strong>{{ emprunt.book.titre }}</strong><br>
                                <small class="text-muted">{{ emprunt.book.auteur }}</small>
                            </td>
                            <td>{{ emprunt.dateEmprunt|date('d/m/Y') }}</td>
                            <td>
                                {{ emprunt.dateRetour ? emprunt.dateRetour|date('d/m/Y') : '<span class="text-muted">Non définie</span>'|raw }}
                            </td>
                            <td>
                                {% if emprunt.dateRetour %} 
                                    <span class="badge bg-success">Rendu</span>
                                {% else %}
                                    <span class="badge bg-warning text-dark">En cours</span>
                                    <a href="{{ path('app_emprunt_rendre', {'id': emprunt.id}) }}" class="btn btn-sm btn-primary mt-1">Rendre</a>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-4">
                                <i>Aucun emprunt enregistré pour le moment.</i>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    
    <div class="mt-3">
        <a href="{{ path('app_book_index') }}" class="btn btn-secondary">Retour à la bibliothèque</a>
    </div>
</div>
{% endblock %}