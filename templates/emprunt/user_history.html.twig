{% extends 'base.html.twig' %}

{% block title %}Mon Historique
{% endblock %}

{% block body %}
	<div class="container mt-5">
		<div class="card shadow-sm border-0">
			<div class="card-header bg-blue-200 text-white p-3 d-flex justify-content-between align-items-center">
				<h1 class="h4 mb-0">
					Historique de
					{{ user.firstName }}
					{{ user.lastName }}</h1>
				<span class="badge bg-white text-primary fw-bold">{{ emprunts|length }}
					emprunt(s)</span>
			</div>

			<div class="table-responsive">
				<table class="table table-hover align-middle mb-0">
					<thead class="table-light">
						<tr>
							<th class="ps-4">Livre</th>
							<th>Date d'emprunt</th>
							<th>Date de retour</th>
							<th class="text-end pe-4">Statut / Action</th>
						</tr>
					</thead>
					<tbody>
						{% for emprunt in emprunts %}
							<tr>
								<td class="ps-4">
									<div class="fw-bold text-dark">{{ emprunt.book.titre }}</div>
									<div class="text-muted small">{{ emprunt.book.auteur }}</div>
								</td>
								<td>
									<span class="text-secondary">📅
										{{ emprunt.dateEmprunt|date('d/m/Y') }}</span>
								</td>
								<td>
									{% if emprunt.dateRetour %}
										<span class="text-secondary">✅
											{{ emprunt.dateRetour|date('d/m/Y') }}</span>
									{% else %}
										<span class="text-danger small italic">Pas encore rendu</span>
									{% endif %}
								</td>
								<td class="text-end pe-4">
									{% if emprunt.dateRetour %}
										<span class="badge bg-success-subtle text-success border border-success px-3">Rendu</span>
									{% else %}
										{# On définit le délai de 14 jours #}
										{% set dateLimite = emprunt.dateEmprunt|date_modify("+2 days") %}

										<div class="d-flex flex-column align-items-end gap-1">
											{% if "now"|date("Y-m-d") > dateLimite|date("Y-m-d") %}
												<span class="badge bg-danger border border-danger px-3 shadow-sm">🚩 EN RETARD</span>
												<small class="text-danger fw-bold" style="font-size: 0.7rem;">Dû depuis le
													{{ dateLimite|date('d/m/Y') }}</small>
											{% else %}
												<span class="badge bg-warning-subtle text-warning-emphasis border border-warning px-3">En cours</span>
												<small class="text-muted" style="font-size: 0.7rem;">À rendre avant le
													{{ dateLimite|date('d/m/Y') }}</small>
											{% endif %}

											<a href="{{ path('app_emprunt_rendre', {'id': emprunt.id}) }}" class="btn btn-sm btn-primary py-0 mt-1" style="font-size: 0.75rem;">
												Rendre le livre
											</a>
										</div>
									{% endif %}
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="4" class="text-center py-5 text-muted">
									<i>Aucun emprunt enregistré pour le moment.</i>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>

		<div class="mt-4">
			<a href="{{ path('app_home') }}" class="btn btn-outline-secondary">
				← Retour à la bibliothèque
			</a>
		</div>
	</div>
{% endblock %}
