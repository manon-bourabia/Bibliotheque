{% extends 'base.html.twig' %}

{% block title %}Bienvenue à la bibliothèque{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="mb-5 text-center fw-bold">Nos Livres</h1>

    <div class="row g-4">
        {% for book in books %}
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm border-0">
                    
                    <a href="{{ path('app_book_show', {'id': book.id}) }}" class="overflow-hidden">
                        <img src="{{ asset('images/' ~ book.image) }}" 
                             class="card-img-top img-hover" 
                             alt="{{ book.titre }}"
                             style="height: 350px; object-fit: cover;">
                    </a>

                    <div class="card-body d-flex flex-column">
                        <a href="{{ path('app_book_show', {'id': book.id}) }}" class="text-decoration-none text-dark">
                            <h5 class="card-title fw-bold mb-1">{{ book.titre }}</h5>
                        </a>
                        
                        <p class="text-muted small mb-3">par {{ book.auteur }}</p>

                        <div class="mt-auto">
                            {% if book.stock > 0 %}
                                <div class="d-grid gap-2">
                                    <a class="btn btn-info" href="{{ path('app_emprunt_new', {'id': book.id}) }}">
                                        Emprunter
                                    </a>
                                    <a class="btn btn-outline-secondary btn-sm" href="{{ path('app_book_show', {'id': book.id}) }}">
                                        Détails
                                    </a>
                                </div>
                            {% else %}
                                <button class="btn btn-light w-100 text-muted" disabled>
                                    Victime de son succès
                                </button>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div> 
</div>
{% endblock %}
